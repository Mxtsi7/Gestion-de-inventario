<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:InventoryControl.UI.ViewModels"
    x:Class="InventoryControl.UI.Views.ProductFormPage"
    x:DataType="vm:ProductFormViewModel"
    Title="{Binding PageTitle}"
    BackgroundColor="{StaticResource Background}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="0">

            <!-- Cabecera del formulario -->
            <Border Padding="20" StrokeShape="RoundRectangle 12" Margin="0,8,0,20"
                    BackgroundColor="{StaticResource Primary}" Stroke="Transparent">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding IsEditMode, Converter={StaticResource BoolToStringConverter}, ConverterParameter='EDITAR|REGISTRO'}" 
                           FontSize="11" TextColor="#B3E5FC" FontAttributes="Bold" CharacterSpacing="1" />
                    <Label Text="{Binding PageTitle}" FontSize="22" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Completa todos los campos del producto"
                           FontSize="13" TextColor="#B3E5FC" />
                </VerticalStackLayout>
            </Border>

            <!-- Campo Nombre -->
            <Label Text="NOMBRE DEL PRODUCTO" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource Border}"
                    BackgroundColor="{StaticResource Surface}" Margin="0,0,0,16">
                <Entry Text="{Binding Name}" Placeholder="Ej: Arroz 1kg"
                       Margin="4,0" ReturnType="Next" />
            </Border>

            <!-- Campo SKU -->
            <Label Text="SKU / C\u00d3DIGO" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource Border}"
                    BackgroundColor="{StaticResource Surface}" Margin="0,0,0,16">
                <Entry Text="{Binding Sku}" Placeholder="Ej: ARR-001"
                       Margin="4,0" ReturnType="Next" />
            </Border>

            <!-- Campo Categoría -->
            <Label Text="CATEGOR\u00cdA" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
            <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource Border}"
                    BackgroundColor="{StaticResource Surface}" Margin="0,0,0,16">
                <Entry Text="{Binding Category}" Placeholder="Ej: Alimentos"
                       Margin="4,0" ReturnType="Next" />
            </Border>

            <!-- Fila precio / stock mínimo -->
            <Grid ColumnDefinitions="*,16,*" Margin="0,0,0,16">
                <VerticalStackLayout Grid.Column="0">
                    <Label Text="PRECIO UNITARIO" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                    <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource Border}"
                            BackgroundColor="{StaticResource Surface}">
                        <Entry Text="{Binding UnitPrice}" Placeholder="0" Keyboard="Numeric"
                               Margin="4,0" />
                    </Border>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2">
                    <Label Text="STOCK M\u00cdNIMO" Style="{StaticResource SectionLabel}" Margin="0,0,0,6" />
                    <Border StrokeShape="RoundRectangle 8" Stroke="{StaticResource Border}"
                            BackgroundColor="{StaticResource Surface}">
                        <Entry Text="{Binding MinimumStockThreshold}" Placeholder="0" Keyboard="Numeric"
                               Margin="4,0" />
                    </Border>
                </VerticalStackLayout>
            </Grid>

            <!-- Error message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="{StaticResource Danger}"
                   FontSize="13"
                   IsVisible="{Binding HasError}"
                   Margin="0,0,0,12" />

            <!-- Botones -->
            <Button Text="{Binding SaveButtonText}"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButton}"
                    IsEnabled="{Binding IsNotBusy}"
                    Margin="0,8,0,8" />

            <Button Text="Cancelar"
                    Command="{Binding CancelCommand}"
                    Style="{StaticResource SecondaryButton}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
