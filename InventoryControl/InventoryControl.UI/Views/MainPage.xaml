<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:InventoryControl.UI.ViewModels"
    xmlns:queries="clr-namespace:InventoryControl.Application.Queries.GetProductList;assembly=InventoryControl.Application"
    xmlns:dto="clr-namespace:InventoryControl.Application.DTOs;assembly=InventoryControl.Application"
    xmlns:conv="clr-namespace:InventoryControl.UI.Enums"
    x:Class="InventoryControl.UI.Views.MainPage"
    x:DataType="vm:MainViewModel"
    Title="Inventario"
    BackgroundColor="{StaticResource Background}">

    <ContentPage.Resources>
        <conv:StatusColorConverter x:Key="StatusColor" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Header con buscador y botón -->
        <Grid Grid.Row="0" Padding="16,16,16,8" ColumnDefinitions="*,Auto"
              BackgroundColor="{StaticResource Surface}"
              Shadow="{Shadow Brush=Black, Offset='0,2', Radius=4, Opacity=0.06}">
            <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                <Label Text="📦 INVENTARIO" Style="{StaticResource SectionLabel}" />
                <Label Text="Control de Productos" Style="{StaticResource CardTitle}" Margin="0,-2,0,0" />
            </VerticalStackLayout>
            <Button Grid.Column="1"
                    Text="+ Nuevo"
                    Command="{Binding GoToFormCommand}"
                    Style="{StaticResource PrimaryButton}"
                    VerticalOptions="Center" />
        </Grid>

        <!-- Lista de productos -->
        <RefreshView Grid.Row="1"
                     Command="{Binding LoadProductsCommand}"
                     IsRefreshing="{Binding IsLoading}">
            <CollectionView ItemsSource="{Binding Products}" Margin="0">

                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Margin="0,60">
                        <Label Text="📋" FontSize="48" HorizontalOptions="Center" />
                        <Label Text="Sin productos registrados" FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" HorizontalOptions="Center" />
                        <Label Text="Toca &quot;+ Nuevo&quot; para agregar el primero"
                               FontSize="14" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:ProductDto">
                        <Border Margin="16,8,16,0" Padding="16" StrokeShape="RoundRectangle 12"
                                BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource Border}" StrokeThickness="1">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">

                                <!-- Nombre y SKU -->
                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding Name}"
                                       Style="{StaticResource CardTitle}" />
                                <Label Grid.Row="1" Grid.Column="0"
                                       Text="{Binding Sku}"
                                       Style="{StaticResource CardSubtitle}" />

                                <!-- Badge de estado -->
                                <Border Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                        Padding="10,5" StrokeShape="RoundRectangle 20"
                                        BackgroundColor="{Binding StatusBadge, Converter={StaticResource StatusColor}}"
                                        VerticalOptions="Center">
                                    <Label Text="{Binding StatusBadge}" TextColor="White"
                                           FontSize="11" FontAttributes="Bold" />
                                </Border>

                                <!-- Info inferior -->
                                <HorizontalStackLayout Grid.Row="2" Grid.ColumnSpan="2"
                                                       Spacing="16" Margin="0,10,0,0">
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="📦" FontSize="13" />
                                        <Label Text="{Binding CurrentStock, StringFormat='Stock: {0}'}"
                                               FontSize="13" TextColor="{StaticResource TextSecondary}" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="🏷️" FontSize="13" />
                                        <Label Text="{Binding Category}"
                                               FontSize="13" TextColor="{StaticResource TextSecondary}" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="💲" FontSize="13" />
                                        <Label Text="{Binding UnitPrice, StringFormat='{0:N0}'}"
                                               FontSize="13" TextColor="{StaticResource TextSecondary}" />
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <BoxView HeightRequest="24" Color="Transparent" />
                </CollectionView.Footer>

            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
