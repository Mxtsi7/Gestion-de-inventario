<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="InventoryControl.UI.Views.ReportesPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:InventoryControl.UI.ViewModels"
    BackgroundColor="{StaticResource ColorFondo}">

    <ContentPage.BindingContext>
        <vm:ReportesViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- NAVBAR -->
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <Label FontAttributes="Bold" FontSize="20" Text="SigmaInventary" TextColor="{StaticResource ColorPrimario}" VerticalOptions="Center" />
                <SearchBar Grid.Column="1" Placeholder="Buscar..." WidthRequest="220" />
                <Border Grid.Column="2" BackgroundColor="{StaticResource ColorPrimario}" HeightRequest="36" StrokeShape="RoundRectangle 18" StrokeThickness="0" VerticalOptions="Center" WidthRequest="36">
                    <Label FontAttributes="Bold" FontSize="13" HorizontalOptions="Center" Text="AU" TextColor="White" VerticalOptions="Center" />
                </Border>
            </Grid>

            <Label FontAttributes="Bold" FontSize="18" Text="Reportes de inventario" TextColor="{StaticResource ColorTexto}" />

            <!-- FILTROS -->
            <Border Style="{StaticResource Tarjeta}">
                <HorizontalStackLayout Spacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label FontSize="12" Text="Desde" TextColor="{StaticResource ColorTextoSuave}" />
                        <Border Padding="8,4" Stroke="{StaticResource ColorBorde}" StrokeShape="RoundRectangle 8" StrokeThickness="1">
                            <DatePicker Date="{Binding FechaInicio}" />
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="4">
                        <Label FontSize="12" Text="Hasta" TextColor="{StaticResource ColorTextoSuave}" />
                        <Border Padding="8,4" Stroke="{StaticResource ColorBorde}" StrokeShape="RoundRectangle 8" StrokeThickness="1">
                            <DatePicker Date="{Binding FechaFin}" />
                        </Border>
                    </VerticalStackLayout>
                    <VerticalStackLayout Spacing="4">
                        <Label FontSize="12" Text="Categoría" TextColor="{StaticResource ColorTextoSuave}" />
                        <Border Padding="4,0" Stroke="{StaticResource ColorBorde}" StrokeShape="RoundRectangle 8" StrokeThickness="1">
                            <Picker
                                ItemsSource="{Binding Categorias}"
                                SelectedItem="{Binding CategoriaSeleccionada}"
                                Title="Todas"
                                WidthRequest="140" />
                        </Border>
                    </VerticalStackLayout>
                    <Button
                        BackgroundColor="{StaticResource ColorPrimario}"
                        Command="{Binding GenerarReporteCommand}"
                        CornerRadius="8"
                        FontAttributes="Bold"
                        Text="Generar"
                        TextColor="White"
                        VerticalOptions="End" />
                </HorizontalStackLayout>
            </Border>

            <!-- TARJETAS RESUMEN -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                <!-- Entradas -->
                <Border Style="{StaticResource Tarjeta}">
                    <VerticalStackLayout Spacing="10">
                        <Label FontSize="12" Text="Total Entradas del período" TextColor="{StaticResource ColorTextoSuave}" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="28"
                            Text="{Binding TotalEntradas}"
                            TextColor="{StaticResource ColorAcento1}" />
                        <GraphicsView
                            Drawable="{Binding SparklineEntradas}"
                            HeightRequest="48"
                            HorizontalOptions="Fill" />
                    </VerticalStackLayout>
                </Border>

                <!-- Salidas -->
                <Border Grid.Column="1" Style="{StaticResource Tarjeta}">
                    <VerticalStackLayout Spacing="10">
                        <Label FontSize="12" Text="Total Salidas del período" TextColor="{StaticResource ColorTextoSuave}" />
                        <Label
                            FontAttributes="Bold"
                            FontSize="28"
                            Text="{Binding TotalSalidas}"
                            TextColor="{StaticResource ColorAcento2}" />
                        <GraphicsView
                            Drawable="{Binding SparklineSalidas}"
                            HeightRequest="48"
                            HorizontalOptions="Fill" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- TABLA RESUMEN POR PRODUCTO -->
            <Border Style="{StaticResource Tarjeta}">
                <VerticalStackLayout Spacing="10">
                    <Label FontAttributes="Bold" FontSize="14" Text="Resumen por producto" TextColor="{StaticResource ColorTexto}" />

                    <!-- Header -->
                    <Grid ColumnDefinitions="*,80,80,90" ColumnSpacing="8">
                        <Label Style="{StaticResource LblHeader}" Text="PRODUCTO" />
                        <Label Grid.Column="1" Style="{StaticResource LblHeader}" Text="ENTRADAS" />
                        <Label Grid.Column="2" Style="{StaticResource LblHeader}" Text="SALIDAS" />
                        <Label Grid.Column="3" Style="{StaticResource LblHeader}" Text="SALDO NETO" />
                    </Grid>

                    <BoxView HeightRequest="1" Color="{StaticResource ColorBorde}" />

                    <CollectionView ItemsSource="{Binding ResumenProductos}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,80,80,90" ColumnSpacing="8" Padding="0,6">
                                    <Label FontAttributes="Bold" FontSize="13" Text="{Binding NombreProducto}" TextColor="{StaticResource ColorTexto}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" FontSize="13" Text="{Binding TotalEntradas}" TextColor="{StaticResource ColorAcento1}" VerticalOptions="Center" />
                                    <Label Grid.Column="2" FontSize="13" Text="{Binding TotalSalidas}" TextColor="{StaticResource ColorAcento2}" VerticalOptions="Center" />
                                    <Label
                                        Grid.Column="3"
                                        FontAttributes="Bold"
                                        FontSize="13"
                                        Text="{Binding SaldoNeto}"
                                        TextColor="{Binding SaldoColor}"
                                        VerticalOptions="Center" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>