<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="InventoryControl.UI.Popups.RegistrarMovimientoPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:InventoryControl.UI.ViewModels"
    CanBeDismissedByTappingOutsideOfPopup="True"
    Color="Transparent">

    <Border
        BackgroundColor="{StaticResource ColorSuperficie}"
        Padding="24"
        StrokeShape="RoundRectangle 20"
        StrokeThickness="0"
        WidthRequest="480">
        <Border.Shadow>
            <Shadow Brush="#6C3EF4" Opacity="0.15" Radius="32" Offset="0,8" />
        </Border.Shadow>

        <VerticalStackLayout Spacing="16">

            <!-- HEADER -->
            <Grid ColumnDefinitions="*,Auto">
                <Label
                    FontAttributes="Bold"
                    FontSize="18"
                    Text="Registrar Movimiento"
                    TextColor="{StaticResource ColorTexto}"
                    VerticalOptions="Center" />
                <Button
                    Grid.Column="1"
                    BackgroundColor="Transparent"
                    Command="{Binding CerrarCommand}"
                    FontSize="18"
                    Text="✕"
                    TextColor="{StaticResource ColorTextoSuave}"
                    WidthRequest="36" />
            </Grid>

            <!-- SELECTOR TIPO -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                <Button
                    BackgroundColor="{Binding EntradaActiva, Converter={StaticResource BoolToEntradaBgConverter}}"
                    BorderColor="{StaticResource ColorAcento1}"
                    BorderWidth="1.5"
                    Command="{Binding SeleccionarEntradaCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    Padding="20,10"
                    Text="Entrada"
                    TextColor="{Binding EntradaActiva, Converter={StaticResource BoolToEntradaFgConverter}}" />
                <Button
                    BackgroundColor="{Binding SalidaActiva, Converter={StaticResource BoolToSalidaBgConverter}}"
                    BorderColor="{StaticResource ColorAcento2}"
                    BorderWidth="1.5"
                    Command="{Binding SeleccionarSalidaCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    Padding="20,10"
                    Text="Salida"
                    TextColor="{Binding SalidaActiva, Converter={StaticResource BoolToSalidaFgConverter}}" />
            </HorizontalStackLayout>

            <!-- FORMULARIO -->
            <VerticalStackLayout Spacing="14">

                <!-- Producto -->
                <VerticalStackLayout Spacing="4">
                    <Label FontSize="12" Text="Producto *" TextColor="{StaticResource ColorTextoSuave}" />
                    <Border Padding="4,0" Stroke="{StaticResource ColorBorde}" StrokeShape="RoundRectangle 8" StrokeThickness="1">
                        <Picker
                            ItemDisplayBinding="{Binding Nombre}"
                            ItemsSource="{Binding Productos}"
                            SelectedItem="{Binding ProductoSeleccionado}" />
                    </Border>
                </VerticalStackLayout>

                <!-- Cantidad -->
                <VerticalStackLayout Spacing="4">
                    <Label FontSize="12" Text="Cantidad *" TextColor="{StaticResource ColorTextoSuave}" />
                    <HorizontalStackLayout Spacing="8">
                        <Button
                            BackgroundColor="{StaticResource ColorFondo}"
                            BorderColor="{StaticResource ColorBorde}"
                            BorderWidth="1"
                            Command="{Binding DecrementarCommand}"
                            CornerRadius="8"
                            Text="−"
                            TextColor="{StaticResource ColorTexto}"
                            WidthRequest="40" />
                        <Border Padding="0" Stroke="{StaticResource ColorBorde}" StrokeShape="RoundRectangle 8" StrokeThickness="1">
                            <Entry
                                HorizontalTextAlignment="Center"
                                Keyboard="Numeric"
                                Text="{Binding Cantidad}"
                                WidthRequest="80" />
                        </Border>
                        <Button
                            BackgroundColor="{StaticResource ColorFondo}"
                            BorderColor="{StaticResource ColorBorde}"
                            BorderWidth="1"
                            Command="{Binding IncrementarCommand}"
                            CornerRadius="8"
                            Text="+"
                            TextColor="{StaticResource ColorTexto}"
                            WidthRequest="40" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <!-- Fecha -->
                <VerticalStackLayout Spacing="4">
                    <Label FontSize="12" Text="Fecha y hora" TextColor="{StaticResource ColorTextoSuave}" />
                    <Border Padding="8,4" Stroke="{StaticResource ColorBorde}" StrokeShape="RoundRectangle 8" StrokeThickness="1">
                        <DatePicker Date="{Binding FechaMovimiento}" />
                    </Border>
                </VerticalStackLayout>

                <!-- Motivo -->
                <VerticalStackLayout Spacing="4">
                    <Label FontSize="12" Text="Motivo" TextColor="{StaticResource ColorTextoSuave}" />
                    <Border Padding="4,0" Stroke="{StaticResource ColorBorde}" StrokeShape="RoundRectangle 8" StrokeThickness="1">
                        <Picker SelectedItem="{Binding MotivoSeleccionado}">
                            <Picker.Items>
                                <x:String>Compra</x:String>
                                <x:String>Venta</x:String>
                                <x:String>Ajuste</x:String>
                                <x:String>Devolución</x:String>
                            </Picker.Items>
                        </Picker>
                    </Border>
                </VerticalStackLayout>

                <!-- Notas -->
                <VerticalStackLayout Spacing="4">
                    <Label FontSize="12" Text="Notas" TextColor="{StaticResource ColorTextoSuave}" />
                    <Border Padding="8" Stroke="{StaticResource ColorBorde}" StrokeShape="RoundRectangle 8" StrokeThickness="1">
                        <Editor
                            HeightRequest="80"
                            Placeholder="Observaciones adicionales..."
                            Text="{Binding Notas}" />
                    </Border>
                </VerticalStackLayout>

            </VerticalStackLayout>

            <!-- FOOTER -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button
                    BackgroundColor="Transparent"
                    BorderColor="{StaticResource ColorBorde}"
                    BorderWidth="1"
                    Command="{Binding CancelarCommand}"
                    CornerRadius="8"
                    Text="Cancelar"
                    TextColor="{StaticResource ColorTextoSuave}" />
                <Button
                    Grid.Column="1"
                    BackgroundColor="{StaticResource ColorPrimario}"
                    Command="{Binding ConfirmarCommand}"
                    CornerRadius="8"
                    FontAttributes="Bold"
                    Text="Confirmar Movimiento"
                    TextColor="White" />
            </Grid>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>