<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="InventoryControl.UI.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- ═══ COLORES SIGMAINVENTARY ═══ -->
            <Color x:Key="ColorPrimario">#6C3EF4</Color>
            <Color x:Key="ColorAcento1">#00C9A7</Color>
            <Color x:Key="ColorAcento2">#FF6B6B</Color>
            <Color x:Key="ColorAcento3">#FFB347</Color>
            <Color x:Key="ColorFondo">#F8F7FF</Color>
            <Color x:Key="ColorSuperficie">#FFFFFF</Color>
            <Color x:Key="ColorTexto">#1A1A2E</Color>
            <Color x:Key="ColorTextoSuave">#6B6B80</Color>
            <Color x:Key="ColorBorde">#E5E7EB</Color>
            <!-- Badge backgrounds -->
            <Color x:Key="BadgeEntradaBg">#E0FBF5</Color>
            <Color x:Key="BadgeEntradaFg">#0a8a6e</Color>
            <Color x:Key="BadgeSalidaBg">#fff0ef</Color>
            <Color x:Key="BadgeSalidaFg">#c94040</Color>
            <Color x:Key="BadgeDisponibleBg">#e0fbf5</Color>
            <Color x:Key="BadgeDisponibleFg">#0a8a6e</Color>
            <Color x:Key="BadgeBajoBg">#fff4e0</Color>
            <Color x:Key="BadgeBajoFg">#c47a00</Color>
            <Color x:Key="BadgeAgotadoBg">#fff0ef</Color>
            <Color x:Key="BadgeAgotadoFg">#c94040</Color>

            <!-- ═══ SHELL ═══ -->
            <Style TargetType="Shell">
                <Setter Property="Shell.BackgroundColor" Value="{StaticResource ColorSuperficie}" />
                <Setter Property="Shell.ForegroundColor" Value="{StaticResource ColorPrimario}" />
                <Setter Property="Shell.TitleColor" Value="{StaticResource ColorTexto}" />
                <Setter Property="Shell.TabBarBackgroundColor" Value="{StaticResource ColorSuperficie}" />
                <Setter Property="Shell.TabBarForegroundColor" Value="{StaticResource ColorPrimario}" />
                <Setter Property="Shell.TabBarUnselectedColor" Value="{StaticResource ColorTextoSuave}" />
                <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource ColorPrimario}" />
            </Style>

            <!-- ═══ BOTONES ═══ -->
            <Style x:Key="BtnPrimario" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorPrimario}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="18,12" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="BtnSecundario" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{StaticResource ColorTextoSuave}" />
                <Setter Property="BorderColor" Value="{StaticResource ColorBorde}" />
                <Setter Property="BorderWidth" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="18,12" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style x:Key="BtnFlotante" TargetType="Button">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorPrimario}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="28" />
                <Setter Property="Padding" Value="14,12" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <!-- ═══ LABELS ═══ -->
            <Style x:Key="LblTitulo" TargetType="Label">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource ColorTexto}" />
            </Style>

            <Style x:Key="LblSubtitulo" TargetType="Label">
                <Setter Property="FontSize" Value="14" />
                <Setter Property="TextColor" Value="{StaticResource ColorTextoSuave}" />
            </Style>

            <Style x:Key="LblCuerpo" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource ColorTexto}" />
            </Style>

            <Style x:Key="LblBadge" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontAttributes" Value="Bold" />
            </Style>

            <Style x:Key="LblHeader" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource ColorTextoSuave}" />
                <Setter Property="TextTransform" Value="Uppercase" />
            </Style>

            <!-- ═══ TARJETA BASE ═══ -->
            <Style x:Key="Tarjeta" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorSuperficie}" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Shadow">
                    <Setter.Value>
                        <Shadow Brush="#6C3EF4" Opacity="0.07" Radius="16" Offset="0,4" />
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ═══ ENTRIES / PICKERS ═══ -->
            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorSuperficie}" />
                <Setter Property="TextColor" Value="{StaticResource ColorTexto}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource ColorTextoSuave}" />
                <Setter Property="FontSize" Value="13" />
            </Style>

            <Style TargetType="Picker">
                <Setter Property="BackgroundColor" Value="{StaticResource ColorSuperficie}" />
                <Setter Property="TextColor" Value="{StaticResource ColorTexto}" />
                <Setter Property="FontSize" Value="13" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>