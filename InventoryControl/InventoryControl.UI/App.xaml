<?xml version="1.0" encoding="UTF-8" ?>
<Application
    x:Class="InventoryControl.UI.App"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Colores principales -->
            <Color x:Key="Primary">#1976D2</Color>
            <Color x:Key="PrimaryDark">#0D47A1</Color>
            <Color x:Key="PrimaryLight">#E3F2FD</Color>
            <Color x:Key="Success">#2E7D32</Color>
            <Color x:Key="Warning">#F57F17</Color>
            <Color x:Key="Danger">#C62828</Color>
            <Color x:Key="Surface">#FFFFFF</Color>
            <Color x:Key="Background">#F5F7FA</Color>
            <Color x:Key="TextPrimary">#1A1A2E</Color>
            <Color x:Key="TextSecondary">#6B7280</Color>
            <Color x:Key="Border">#E5E7EB</Color>

            <!-- Estilos globales -->
            <Style TargetType="Shell">
                <Setter Property="Shell.BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="Shell.ForegroundColor" Value="White" />
                <Setter Property="Shell.TitleColor" Value="White" />
            </Style>

            <Style TargetType="Button" x:Key="PrimaryButton">
                <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style TargetType="Button" x:Key="SecondaryButton">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="{StaticResource Primary}" />
                <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                <Setter Property="BorderWidth" Value="1.5" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="16,12" />
                <Setter Property="FontSize" Value="14" />
            </Style>

            <Style TargetType="Entry">
                <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="PlaceholderColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="FontSize" Value="15" />
            </Style>

            <Style TargetType="Label" x:Key="SectionLabel">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CharacterSpacing" Value="1" />
            </Style>

            <Style TargetType="Label" x:Key="CardTitle">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>

            <Style TargetType="Label" x:Key="CardSubtitle">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
