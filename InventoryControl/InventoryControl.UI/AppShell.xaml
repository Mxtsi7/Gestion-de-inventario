<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="InventoryControl.UI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:InventoryControl.UI.Views"
    Shell.TabBarBackgroundColor="{StaticResource ColorSuperficie}"
    Shell.TabBarForegroundColor="{StaticResource ColorPrimario}"
    Shell.TabBarUnselectedColor="{StaticResource ColorTextoSuave}">

    <TabBar>
        <ShellContent
            Title="Inicio"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Icon="icon_dashboard.png"
            Route="dashboard" />

        <ShellContent
            Title="Productos"
            ContentTemplate="{DataTemplate views:ProductosPage}"
            Icon="icon_package.png"
            Route="productos" />

        <ShellContent
            Title="Entradas"
            ContentTemplate="{DataTemplate views:MovimientosPage}"
            Icon="icon_entry.png"
            Route="movimientos" />

        <ShellContent
            Title="Reportes"
            ContentTemplate="{DataTemplate views:ReportesPage}"
            Icon="icon_reports.png"
            Route="reportes" />
    </TabBar>
</Shell>