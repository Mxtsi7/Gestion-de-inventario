<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="InventoryControl.UI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:InventoryControl.UI.Views"
    Shell.NavBarIsVisible="False">

    <TabBar>
        <ShellContent
            Title="Inicio"
            Icon="home.png"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="dashboard" />
        <ShellContent
            Title="Productos"
            Icon="box.png"
            ContentTemplate="{DataTemplate views:ProductsPage}"
            Route="products" />
        <ShellContent
            Title="Movimientos"
            Icon="swap.png"
            ContentTemplate="{DataTemplate views:MovementsPage}"
            Route="movements" />
        <ShellContent
            Title="Reportes"
            Icon="chart.png"
            ContentTemplate="{DataTemplate views:ReportsPage}"
            Route="reports" />
    </TabBar>
</Shell>